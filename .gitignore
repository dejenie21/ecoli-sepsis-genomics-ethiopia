# Block all raw sequencing data formats
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# Block all genome assemblies completely
*.fasta
*.fa
*.fna
*.gff

# Block the entire assembled genomes folder completely
data/assembled_genomes/
data/assembled_genomes/*

# Block bioinformatic mapping/variant formats
*.bam
*.bai
*.sam
*.vcf
*.vcf.gz

# Block system and operational work logs
.DS_Store
.Rhistory
.Rproj.user/
__pycache__/
.nextflow/
work/

# Block raw or preprocessed trimmed read folders from sequence runs
data/trimmed_reads/
data/trimmed_reads/*

# Block reference genomes from tracking overhead bounds
data/references/
data/references/*
